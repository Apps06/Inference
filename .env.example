# === Gemini API Keys (Primary) — one per agent ===
GEMINI_KEY_1=your-gemini-key-1
GEMINI_KEY_2=your-gemini-key-2
GEMINI_KEY_3=your-gemini-key-3
GEMINI_KEY_4=your-gemini-key-4
GEMINI_KEY_5=your-gemini-key-5

# === OpenAI API Keys (Fallback) — one per agent ===
OPENAI_KEY_1=your-openai-key-1
OPENAI_KEY_2=your-openai-key-2
OPENAI_KEY_3=your-openai-key-3
OPENAI_KEY_4=your-openai-key-4
OPENAI_KEY_5=your-openai-key-5

# === Default Model ===
# Gemini model used as primary (e.g. gemini-2.5-flash, gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-flash
# OpenAI model used as fallback (e.g. gpt-4o-mini, gpt-4o)
OPENAI_MODEL=gpt-4o-mini

# === Server ===
HOST=0.0.0.0
PORT=8000
